      <aliases enabled='yes' />
      <column caption='Booking Status' datatype='string' name='[Booking_Status]' role='dimension' type='nominal' />
      <column aggregation='Hour' caption='Booking Time' datatype='datetime' name='[Booking_Time]' role='dimension' type='ordinal' />
      <column caption='count of ride' datatype='integer' name='[Calculation_1088463746416668672]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Ride_ID])' />
      </column>
      <column caption='Total rides' datatype='integer' name='[Calculation_372391405623619589]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Ride_ID])' />
      </column>
      <column caption='Completed rides' datatype='integer' name='[Calculation_372391405627654150]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [Booking_Status] = &quot;Completed&quot;&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Cancelled rides' datatype='integer' name='[Calculation_372391405628100615]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;IF [Booking_Status] = &quot;Cancelled&quot;&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Total revenue' datatype='real' default-format='c&quot;₹&quot;#,##0;(&quot;₹&quot;#,##0)' name='[Calculation_372391405629620232]' role='measure' type='quantitative' visual-totals='Sum'>
        <calculation class='tableau' formula='SUM([Fare])' />
      </column>
      <column caption='Avg fare' datatype='real' default-format='c&quot;₹&quot;#,##0;(&quot;₹&quot;#,##0)' name='[Calculation_372391405630287881]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Fare])' />
      </column>
      <column caption='Average rating' datatype='real' name='[Calculation_372391405631045642]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Rating])' />
      </column>
      <column caption='Booking Hour' datatype='datetime' datatype-customized='true' name='[Calculation_372391405638959115]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEPARSE ( &quot;HH&quot;, STR(DATEPART(&apos;hour&apos;,[Booking_Time])) ) ' />
      </column>
      <column caption='Cancellation rate' datatype='real' name='[Calculation_372391405644959756]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;SUM(&#13;&#10;IF [Booking_Status]=&quot;Cancelled&quot;&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([Ride_ID])&#13;&#10;)*100' />
      </column>
      <column caption='Revenue per ride' datatype='real' default-format='c&quot;₹&quot;#,##0;(&quot;₹&quot;#,##0)' name='[Calculation_372391405645320205]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Fare])&#13;&#10;/&#13;&#10;COUNT([Ride_ID])' />
      </column>
      <column caption='Estimated Rapido Commission' datatype='real' default-format='c&quot;$&quot;#,##0,.00K;(&quot;$&quot;#,##0,.00K)' name='[Calculation_372391405645484046]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Fare])*0.20' />
      </column>
      <column caption='Average Distance' datatype='real' name='[Calculation_372391405645660175]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Distance_km])' />
      </column>
      <column caption='Unique Customer' datatype='integer' name='[Calculation_926052685151186944]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Customer_ID])' />
      </column>
      <column caption='Unique Captain' datatype='integer' name='[Calculation_926052685151891457]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Captain_ID])' />
      </column>
